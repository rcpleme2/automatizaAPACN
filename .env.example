# ============================================================
# Configurações do Nota Paraná
# Copie este arquivo para .env e preencha os valores reais.
# O arquivo .env NUNCA deve ser commitado no repositório.
# ============================================================

# CPF ou CNPJ do titular da conta (somente números)
NOTAPARANA_USER=seu_cpf_ou_cnpj_aqui

# Senha de acesso ao portal Nota Paraná / Identidade Digital SEFA-PR
NOTAPARANA_PASSWORD=sua_senha_segura

# CNPJ da entidade que receberá as doações (somente números, 14 dígitos)
NOTAPARANA_CNPJ_ENTIDADE=00000000000000
